{
  "name": "sentence_translation_slim",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "sentences",
      "chunks",
      "components"
    ],
    "properties": {
      "sentences": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sentenceId",
            "meaning"
          ],
          "properties": {
            "sentenceId": {
              "type": "string"
            },
            "meaning": {
              "type": "string"
            }
          }
        }
      },
      "chunks": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chunkId",
            "meaning"
          ],
          "properties": {
            "chunkId": {
              "type": "string"
            },
            "meaning": {
              "type": "string"
            }
          }
        }
      },
      "components": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "componentId",
            "meaning",
            "explanation"
          ],
          "properties": {
            "componentId": {
              "type": "string"
            },
            "meaning": {
              "type": "string"
            },
            "explanation": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
