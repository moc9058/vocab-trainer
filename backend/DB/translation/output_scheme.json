{
  "name": "sentence_decomposition",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "inputText",
      "sentences"
    ],
    "properties": {
      "inputText": {
        "type": "string"
      },
      "sentences": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sentenceId",
            "text",
            "components"
          ],
          "properties": {
            "sentenceId": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "components": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "componentId",
                  "surface",
                  "baseForm",
                  "reading",
                  "partOfSpeech",
                  "meaning",
                  "explanation"
                ],
                "properties": {
                  "componentId": {
                    "type": "string"
                  },
                  "surface": {
                    "type": "string"
                  },
                  "baseForm": {
                    "type": ["string", "null"]
                  },
                  "reading": {
                    "type": ["string", "null"]
                  },
                  "partOfSpeech": {
                    "type": "string",
                    "enum": [
                      "noun",
                      "verb",
                      "adjective",
                      "adverb",
                      "pronoun",
                      "preposition",
                      "conjunction",
                      "interjection",
                      "determiner",
                      "particle",
                      "classifier",
                      "numeral",
                      "onomatopoeia",
                      "idiom",
                      "set phrase",
                      "phrasal verb",
                      "collocation",
                      "proverb",
                      "greeting"
                    ]
                  },
                  "meaning": {
                    "type": "string"
                  },
                  "explanation": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
