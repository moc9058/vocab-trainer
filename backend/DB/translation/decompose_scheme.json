{
  "name": "sentence_decomposition",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "sentences"
    ],
    "properties": {
      "sentences": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sentenceId",
            "text",
            "chunks"
          ],
          "properties": {
            "sentenceId": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "chunks": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "chunkId",
                  "surface",
                  "components"
                ],
                "properties": {
                  "chunkId": {
                    "type": "string"
                  },
                  "surface": {
                    "type": "string"
                  },
                  "components": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "componentId",
                        "surface",
                        "baseForm",
                        "reading",
                        "partOfSpeech"
                      ],
                      "properties": {
                        "componentId": {
                          "type": "string"
                        },
                        "surface": {
                          "type": "string"
                        },
                        "baseForm": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "reading": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "partOfSpeech": {
                          "type": "string",
                          "enum": [
                            "noun",
                            "verb",
                            "adjective",
                            "adverb",
                            "pronoun",
                            "preposition",
                            "conjunction",
                            "interjection",
                            "determiner",
                            "particle",
                            "classifier",
                            "numeral",
                            "onomatopoeia",
                            "idiom",
                            "set phrase",
                            "phrasal verb",
                            "prepositional verb",
                            "collocation",
                            "proverb",
                            "greeting",
                            "auxiliary",
                            "copula",
                            "suffix",
                            "prefix",
                            "bound noun",
                            "ending"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}