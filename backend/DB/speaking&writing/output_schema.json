{
  "name": "speaking_writing_correction",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["sentences", "overallFeedback"],
    "properties": {
      "sentences": {
        "type": "array",
        "description": "Per-sentence corrections, in the same order as the original input",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["original", "corrected", "corrections"],
          "properties": {
            "original": {
              "type": "string",
              "description": "The original sentence from the user's input"
            },
            "corrected": {
              "type": "string",
              "description": "The corrected version of this sentence"
            },
            "corrections": {
              "type": "array",
              "description": "Individual corrections within this sentence, ordered by their position in the original text",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["original", "corrected", "explanation", "severity"],
                "properties": {
                  "original": {
                    "type": "string",
                    "description": "The problematic fragment from the sentence"
                  },
                  "corrected": {
                    "type": "string",
                    "description": "The corrected fragment"
                  },
                  "explanation": {
                    "type": "string",
                    "description": "Why this change was made"
                  },
                  "severity": {
                    "type": "string",
                    "enum": ["error", "improvement", "style"],
                    "description": "error = grammatical mistake, improvement = awkward but not wrong, style = stylistic suggestion"
                  }
                }
              }
            }
          }
        }
      },
      "overallFeedback": {
        "type": "string",
        "description": "A brief overall assessment of the learner's text"
      }
    }
  }
}
